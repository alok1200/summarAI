# =============================================================================
# SummarAI — Environment Variables (REAL VALUES — DO NOT COMMIT)
# =============================================================================
# This file is gitignored. Edit it with your real credentials.
# Use .env.example as a reference for what each variable does.
# =============================================================================

# --- DATABASE (REQUIRED) ---
# SQLite (default). To switch to PostgreSQL/MySQL, see .env.example.
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# --- SESSION SECURITY ---
# Generate one with:  openssl rand -hex 32
# If empty, the app falls back to random tokens (still secure, but sessions
# won't survive a server restart in production).
SESSION_SECRET=""

# --- Z.AI LLM API ---
# Pre-configured in this environment by default. Set this only if you're
# deploying elsewhere (Vercel / your own server / another cloud).
ZAI_API_KEY=""
LLM_MODEL=""
LLM_VISION_MODEL="glm-4v-flash"

# --- YOUTUBE DATA API (optional, for stricter metadata fetching) ---
YOUTUBE_API_KEY=""

# --- APP RUNTIME ---
PORT=3000
NODE_ENV="development"
NEXT_PUBLIC_APP_URL=""

# --- OAUTH (reserved for future use) ---
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# --- FILE STORAGE (reserved for future use) ---
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
