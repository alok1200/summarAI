# =============================================================================
# SummarAI — Environment Variables Template
# =============================================================================
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# `.env` and `.env.local` are gitignored — never commit real secrets.
# `.env.example` is safe to commit (it only has placeholders).
#
# Next.js automatically loads `.env` and `.env.local` at runtime.
#
# -----------------------------------------------------------------------------
# THE ONE RULE THAT GOVERNS THIS WHOLE FILE
# -----------------------------------------------------------------------------
# For every API key below:
#
#   • If you FILL IT IN  → the app uses YOUR key for that service.
#   • If you LEAVE IT EMPTY → the app falls back to its built-in default
#     behaviour and keeps running with zero configuration.
#
# In other words: you don't have to fill anything in. The app already works
# out of the box. Only fill in a key when you want to override the default.
#
#   Service          | Empty value behaviour (the default)
#   -----------------+----------------------------------------------------------
#   ZAI_API_KEY      | Uses the pre-installed SDK config at /etc/.z-ai-config
#                    | (this is what makes chat / summaries / vision work today).
#   YOUTUBE_API_KEY  | Falls back to public oEmbed + 4 transcript strategies
#                    | (InnerTube / watch-page / npm pkg / youtubei.js).
#                    | Works for the vast majority of videos without a key.
#   SESSION_SECRET   | Falls back to random per-process session tokens (still
#                    | cryptographically secure; sessions just won't survive
#                    | a server restart in production).
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# 1. DATABASE  (REQUIRED — no default)
# -----------------------------------------------------------------------------
# Prisma database connection string.
#
# SQLite (default — zero-config, file-based, great for dev):
#   Format: file:<absolute-path-to-db-file>
DATABASE_URL="file:./db/custom.db"
#
# PostgreSQL (recommended for production):
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"
#   Example: "postgresql://postgres:password@localhost:5432/sumarai?schema=public"
#
# MySQL:
#   DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DBNAME"
#
# NOTE: if you switch DB providers, also update `provider` in prisma/schema.prisma
# (sqlite → postgresql / mysql) and run `npm run db:push` to recreate the schema.
#
# ─── SQLite backup configuration (OPTIONAL — only used when DATABASE_URL is sqlite) ───
# `npm run db:backup` creates a timestamped, transactionally-consistent snapshot
# of the SQLite DB via `VACUUM INTO`. Backups land in BACKUP_DIR and are pruned
# to BACKUP_RETENTION count automatically. Designed to be cron-friendly:
#
#   # crontab — daily 3am backup, keep last 30 days
#   0 3 * * *  cd /path/to/app && npm run db:backup >> /var/log/db-backup.log 2>&1
#
# Other commands:
#   npm run db:backup:list    # list existing backups (newest first)
#   npm run db:backup:prune   # delete backups beyond retention
#   npm run db:restore <name> # restore from a backup (creates a safety backup first)
#
# BACKUP_DIR="backups"          # where to save backups (default: ./backups)
# BACKUP_RETENTION="30"         # number of backups to keep (default: 30)
# BACKUP_COMPRESS="1"           # "1" = gzip backups (default), "0" = plain .db


# -----------------------------------------------------------------------------
# 2. SESSION SECURITY  (OPTIONAL — random fallback if empty)
# -----------------------------------------------------------------------------
# Secret used to HMAC-sign session tokens. If left empty, the app falls back
# to pure random tokens (still secure, but sessions won't survive a server
# restart). Set this for any production deployment.
#
# Generate one with:  openssl rand -hex 32
# or:                  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""


# -----------------------------------------------------------------------------
# 3. Z.AI LLM API  (OPTIONAL — pre-configured env default if empty)
# -----------------------------------------------------------------------------
# The z-ai-web-dev-sdk ships with a pre-installed config at /etc/.z-ai-config
# in this environment, so chat / summaries / interview Q&A / vision all work
# WITHOUT you setting anything here. That is the "default behaviour".
#
# To override it (e.g. when deploying to Vercel / your own server / another
# cloud where /etc/.z-ai-config doesn't exist), get an API key from
# https://z.ai and set it here. The app will then use YOUR key instead.
#
# Leave empty → use the default. Fill in → use yours.
ZAI_API_KEY=""

# Optional: override the Z.ai API base URL. Defaults to https://api.z.ai/v1
# when ZAI_API_KEY is set. Ignored when ZAI_API_KEY is empty (because the
# SDK then uses whatever baseUrl is in /etc/.z-ai-config).
ZAI_BASE_URL=""

# LLM model name to use for chat / summaries / interview Q&A.
# Leave empty → let the SDK pick its current production model.
# Example: "glm-4.6", "glm-4-plus", "glm-4-air"
LLM_MODEL=""

# Vision model name (for image analysis in chat).
# Leave empty → defaults to "glm-4v-flash".
LLM_VISION_MODEL="glm-4v-flash"


# -----------------------------------------------------------------------------
# 4. YOUTUBE DATA API  (OPTIONAL — oEmbed fallback if empty)
# -----------------------------------------------------------------------------
# The app fetches transcripts via 4 fallback strategies (InnerTube, watch-page
# scrape, youtube-transcript package, youtubei.js) — no API key needed for the
# vast majority of videos.
#
# For videos where ALL 4 fallbacks get bot-blocked, the app currently shows a
# "paste transcript manually" dialog. If you want to also fetch video METADATA
# (title, channel, thumbnail) reliably even when the watch page is blocked,
# set YOUTUBE_API_KEY here. If empty, the app falls back to the public oEmbed
# endpoint (works for most non-age-restricted videos, no key needed).
#
# Get a key from: https://console.cloud.google.com/ → APIs & Services →
# Credentials → Create API key → enable "YouTube Data API v3".
YOUTUBE_API_KEY=""


# -----------------------------------------------------------------------------
# 4b. YOUTUBE PROXY  (OPTIONAL — IP-level rate-limit workaround if empty)
# -----------------------------------------------------------------------------
# When YouTube rate-limits this server's IP (the dreaded "Sign in to confirm
# you're not a bot" block), all 4 in-process transcript strategies fail
# simultaneously because they all originate from the same IP. There is no
# pure-code fix — the only workaround is to route the requests through a
# DIFFERENT IP.
#
# YOUTUBE_PROXY_URL is a URL-prefix that gets prepended to every outbound
# YouTube fetch (cookie warming, InnerTube player, watch-page scrape, caption
# track fetch). The proxy is expected to be a simple reverse proxy (Cloudflare
# Worker / nginx / Caddy / a tiny Express app) running on a different IP than
# this server. YouTube's rate limiter then sees the proxy's IP, not ours.
#
# Examples:
#   YOUTUBE_PROXY_URL="https://my-yt-proxy.example.workers.dev/?url="
#   YOUTUBE_PROXY_URL="https://user:pass@proxy.example.com/"
#
# Format: any string. The original YouTube URL is appended verbatim, so the
# proxy must accept `?<proxy-prefix><full-youtube-url>` and return the
# response body verbatim (with Set-Cookie headers preserved for cookie
# warming to work).
#
# Leave empty (the default) → all requests go direct from this server's IP.
# When a block happens anyway, the user is shown a "Paste transcript
# manually" panel as a client-side fallback (works regardless of this env
# var).
#
# NOTE: this only proxies the fetches in src/lib/youtube-transcript.ts. The
# youtube-transcript npm package and youtubei.js make their own internal
# fetches that we can't intercept, so those strategies still hit YouTube
# directly. The proxy primarily helps strategies 1 (ANDROID) and 2 (watch-
# page) — which are the most reliable anyway.
YOUTUBE_PROXY_URL=""


# -----------------------------------------------------------------------------
# 5. APP RUNTIME CONFIG  (OPTIONAL — sensible defaults)
# -----------------------------------------------------------------------------
# Port the dev server listens on. Default: 3000.
PORT=3000

# Node environment. Use "production" for deployed builds, "development" for dev.
NODE_ENV="development"

# Public base URL of the deployed app (used for absolute URLs in emails / OAuth
# callbacks / shareable links). Leave empty for dev.
NEXT_PUBLIC_APP_URL=""

# -----------------------------------------------------------------------------
# 5a. PRODUCTION HARDENING  (OPTIONAL — sensible defaults)
# -----------------------------------------------------------------------------
# All of these have safe defaults; you only need to set them to override.

# Per-user rate limit for AI/LLM endpoints (/api/chat, /api/youtube-summary,
# /api/youtube-interview, /api/youtube-load). Default: 10 requests per minute.
# Increase for power users, decrease to save LLM API costs.
# RATE_LIMIT_AI_PER_MIN="10"

# Max request body size in bytes for API routes that read JSON. Default: 2 MB
# (allows pasted YouTube transcripts). Decrease if you want stricter limits.
# MAX_BODY_BYTES="2097152"

# Log level for structured JSON logs. Default: "info" in production, "debug"
# in development. Set to "warn" or "error" for quieter logs.
# LOG_LEVEL="info"



# -----------------------------------------------------------------------------
# 6. OAUTH PROVIDERS  (OPTIONAL — for "Sign in with Google")
# -----------------------------------------------------------------------------
# Google OAuth — adds a "Sign in with Google" button to the login/signup
# screen. The button is always shown; if these env vars are NOT set, clicking
# it returns a 503 with setup instructions, so leave them empty if you don't
# want to set up Google OAuth yet.
#
# Setup (5 minutes):
#   1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
#   2. Create a new project (or pick an existing one)
#   3. "+ CREATE CREDENTIALS" → "OAuth client ID"
#      - Application type: Web application
#      - Authorized JavaScript origins: https://YOUR-DOMAIN
#      - Authorized redirect URIs: https://YOUR-DOMAIN/api/auth/google/callback
#   4. Copy the Client ID and Client Secret into the env vars below
#   5. Set GOOGLE_REDIRECT_URI to the FULL public URL of the callback route:
#        - Dev:    http://localhost:3000/api/auth/google/callback
#        - Prod:   https://YOUR-DOMAIN/api/auth/google/callback
#
# Scopes requested: openid, email, profile (just enough to identify the user).
# We do NOT request any other Google API access (Drive, Calendar, etc.).
#
# Account-linking behavior:
#   - If a user signs up with email/password first, then later signs in with
#     Google using the SAME email, we link the Google account to the existing
#     user (they can sign in with either method).
#   - Google-only users have no password (passwordHash is null in the DB).
#
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""

# GitHub OAuth: https://github.com/settings/developers
# (Reserved for future use — not yet implemented.)
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""


# -----------------------------------------------------------------------------
# 7. FILE UPLOADS / STORAGE  (OPTIONAL — for attachment features)
# -----------------------------------------------------------------------------
# Currently file attachments are stored in-browser as data URLs (no server-side
# storage needed). If you want to persist uploads to S3 / R2 / GCS later,
# configure these.
#
# S3-compatible (AWS S3, Cloudflare R2, MinIO, etc.):
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
