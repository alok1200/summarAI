// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String

  // Password hash — nullable because OAuth-only users (Google Sign-In) have
  // no password. Email/password users always have this set.
  passwordHash String?

  // OAuth fields — nullable because email/password users have no OAuth
  // provider. When `provider` is set, `providerAccountId` is the unique ID
  // returned by the OAuth provider (e.g. Google's `sub` claim).
  provider          String? // "credentials" (default) | "google"
  providerAccountId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  Session[]
  transcripts Transcript[]

  // Speeds up OAuth login lookups: WHERE provider=? AND providerAccountId=?
  @@index([provider, providerAccountId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Vector search — transcripts + chunks
//
// When a user loads a YouTube video, we persist the transcript and embed each
// chunk with a local Transformers.js model (Xenova/all-MiniLM-L6-v2, 384-dim).
// At chat time, we embed the user's question and do cosine similarity search
// to pick the top-K chunks — 1000× cheaper and 100× faster than the previous
// LLM-as-retriever approach.
//
// Storage strategy:
//   - `embedding` is stored as a BLOB containing Float32Array.buffer
//     (384 floats × 4 bytes = 1536 bytes per chunk)
//   - Cosine similarity runs in pure JS — fast enough for thousands of chunks
//     (<10ms for 10k chunks on commodity hardware)
//   - No sqlite-vec C-extension needed, no extra infrastructure
//
// Why store per-user: each user has their own transcript library. A future
// "search across all my videos" feature queries by (userId, similarity).
// ---------------------------------------------------------------------------

model Transcript {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // YouTube video ID (11 chars) — one transcript per (userId, videoId)
  videoId   String

  title     String   @default("(untitled)")
  author    String?

  // Total transcript length in characters (for display + cache decisions)
  lengthChars Int   @default(0)

  // Number of chunks this transcript was split into
  chunkCount Int    @default(0)

  // Whether embeddings have been generated for all chunks
  embedded  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks    TranscriptChunk[]

  @@unique([userId, videoId])
  @@index([userId])
}

model TranscriptChunk {
  id           String   @id @default(cuid())
  transcriptId String
  transcript   Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)

  // 0-indexed position of this chunk within the transcript
  chunkIndex   Int

  // The actual text content of this chunk (~22K chars max)
  text         String

  // 384-dim Float32 embedding as raw bytes (Float32Array.buffer)
  // NULL until embeddings have been generated
  embedding    Bytes?

  @@index([transcriptId])
  @@index([chunkIndex])
}
