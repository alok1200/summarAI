// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String

  // Password hash — nullable because OAuth-only users (Google Sign-In) have
  // no password. Email/password users always have this set.
  passwordHash String?

  // OAuth fields — nullable because email/password users have no OAuth
  // provider. When `provider` is set, `providerAccountId` is the unique ID
  // returned by the OAuth provider (e.g. Google's `sub` claim).
  provider          String? // "credentials" (default) | "google"
  providerAccountId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  Session[]

  // Speeds up OAuth login lookups: WHERE provider=? AND providerAccountId=?
  @@index([provider, providerAccountId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
